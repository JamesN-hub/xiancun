rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: families
    // Fields:
    //   - name: string (1-100 chars)
    //   - ownerUid: string (UID of creator)
    //   - members: list (list of UIDs)
    //
    // Collection: items
    // Fields:
    //   - familyId: string (ID of parent family)
    //   - name: string (1-100 chars)
    //   - category: string ('fridge' | 'freezer')
    //   - purchaseDate: string (ISO date)
    //   - expiryDays: int (>= 0)
    //   - addedBy: string (UID)
    //   - addedByName: string (Display Name)
    //   - createdAt: string (ISO date)
    //
    // Collection: users
    // Fields:
    //   - uid: string
    //   - email: string
    //   - role: string ('admin' | 'user')
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          (request.auth.token.email == "how5708@gmail.com" && request.auth.token.email_verified == true));
    }
    
    function isMemberOfFamily(familyId) {
      return isAuthenticated() && 
        (request.auth.uid in get(/databases/$(database)/documents/families/$(familyId)).data.members);
    }

    function isValidFamily(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.ownerUid is string &&
             data.members is list && data.members.size() > 0 && data.members.size() < 20;
    }

    function isValidItem(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.category in ['fridge', 'freezer'] &&
             data.purchaseDate is string &&
             data.expiryDays is int && data.expiryDays >= 0 &&
             data.familyId is string &&
             data.addedBy == request.auth.uid &&
             data.addedByName is string && data.addedByName.size() > 0 && data.addedByName.size() < 100 &&
             data.createdAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    match /families/{familyId} {
      allow create: if isAuthenticated() && isValidFamily(request.resource.data) && request.resource.data.ownerUid == request.auth.uid;
      allow read: if isAuthenticated() && (request.auth.uid in resource.data.members || isAdmin());
      allow update: if isAuthenticated() && (
        ((resource.data.ownerUid == request.auth.uid || isAdmin()) && isValidFamily(request.resource.data)) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members']) && 
         request.auth.uid in request.resource.data.members)
      );
      allow delete: if isAdmin();
    }

    match /items/{itemId} {
      allow read: if isAuthenticated() && (isMemberOfFamily(resource.data.familyId) || isAdmin());
      
      allow create: if isAuthenticated() && 
                    (isMemberOfFamily(request.resource.data.familyId) || isAdmin()) && 
                    isValidItem(request.resource.data);
      
      allow update: if isAuthenticated() && 
                    (isMemberOfFamily(request.resource.data.familyId) || isAdmin()) && 
                    isValidItem(request.resource.data);
                    
      allow delete: if isAuthenticated() && (isMemberOfFamily(resource.data.familyId) || isAdmin());
    }
  }
}
